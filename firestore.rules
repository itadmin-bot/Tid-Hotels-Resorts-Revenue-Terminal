rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // HELPER FUNCTIONS
    // =====================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function notDeleted() {
      return !("isDeleted" in resource.data) || resource.data.isDeleted == false;
    }

    // =====================================================
    // USERS COLLECTION
    // =====================================================
    match /users/{userId} {
      // Admin full access
      allow read, write, delete: if isAdmin();

      // Normal user can read/write only their own profile
      allow read, write: if isSignedIn() &&
        request.auth.uid == userId;
    }

    // =====================================================
    // TRANSACTIONS COLLECTION
    // =====================================================
    match /transactions/{transactionId} {
      // ADMIN full access
      allow read, write, delete: if isAdmin();

      // USER read their own transactions
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.createdBy) &&
        notDeleted();

      // USER create their own transaction
      allow create: if isSignedIn() &&
        (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);

      // USER update settlement fields only
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.createdBy) &&
        request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            "status",
            "paidAmount",
            "amountPaid",
            "balance",
            "settledAt",
            "updatedAt",
            "settlementMethod",
            "selectedBank",
            "payments",
            "guestName",
            "email",
            "phone"
          ]);

      // No user deletes
      allow delete: if false;
    }

    // =====================================================
    // FINANCIAL LEDGER
    // =====================================================
    match /ledger/{entryId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // ACCESS CODES
    // =====================================================
    match /accessCodes/{codeId} {
      allow read, write, delete: if isAdmin();
      allow get: if isSignedIn();
    }

    // =====================================================
    // ROOMS
    // =====================================================
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin();
    }

    // =====================================================
    // MENU
    // =====================================================
    match /menu/{menuId} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin();
    }

    // =====================================================
    // SETTINGS
    // =====================================================
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin();
    }
  }
}